{
  "name": "medquiz-app",
  "version": "1.2.8",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "parse:data": "node scripts/parse-data-folder.mjs",
    "import:data": "node scripts/import-parsed-json.mjs",
    "reimport:data": "node scripts/import-parsed-json.mjs --reset",
    "import:supabase": "node scripts/import-to-supabase.mjs",
    "reimport:supabase": "node scripts/import-to-supabase.mjs --force-reset",
    "sync:metadata:supabase": "node scripts/sync-question-metadata.mjs",
    "seed:tokens:supabase": "node scripts/seed-tokens-supabase.mjs",
    "seed:data-once": "npm run parse:data && npm run import:data",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/uuid": "^10.0.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
